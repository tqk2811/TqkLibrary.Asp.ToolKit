<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<!--https://docs.microsoft.com/en-us/nuget/reference/nuspec-->
	<metadata>
		<id>$id$</id>
		<version>$version$</version>
		<description>HTTP integration helpers (typed HttpClient factory, download/post helpers, cookie persistence) for ASP.NET Core services.</description>
		<authors>tqk2811</authors>
		<projectUrl>https://github.com/tqk2811/TqkLibrary.Asp.ToolKit</projectUrl>
		<repository type="git" url="https://github.com/tqk2811/TqkLibrary.Asp.ToolKit.git"/>
		<license type="expression">MIT</license>
		<readme>docs\README.md</readme>
		<dependencies>
			<group targetFramework="net10.0">
				<dependency id="Microsoft.AspNetCore.Http.Extensions" version="2.3.9" />
				<dependency id="Microsoft.AspNetCore.Identity" version="2.3.9" />
				<dependency id="Microsoft.Extensions.Configuration" version="10.0.7" />
				<dependency id="Microsoft.Extensions.Http" version="10.0.7" />
				<dependency id="Newtonsoft.Json" version="13.0.4" />
				<dependency id="System.Security.Cryptography.Xml" version="10.0.7" />
				<dependency id="TqkLibrary.Http" version="1.1.2.14" />
				<dependency id="TqkLibrary.Utils" version="1.0.0-build20260320155740" />
			</group>
		</dependencies>
	</metadata>
	<files>
		<file src="..\..\README.md" target="docs\" />
		<file src="bin\Release\net10.0\TqkLibrary.Asp.ToolKit.Integration.dll" target="lib\net10.0\" />
	</files>
</package>
